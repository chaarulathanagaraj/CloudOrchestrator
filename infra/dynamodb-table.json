{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "DynamoDB table for CloudCost Guard audit logs",
  "Resources": {
    "ResourceAuditLogTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "resource_audit_log",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          {
            "AttributeName": "pk",
            "AttributeType": "S"
          },
          {
            "AttributeName": "sk",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "pk",
            "KeyType": "HASH"
          },
          {
            "AttributeName": "sk",
            "KeyType": "RANGE"
          }
        ]
      }
    }
  }
}
