{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "SNS topic for CloudCost Guard alerts",
  "Resources": {
    "AlertsTopic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "alerts"
      }
    },
    "AlertsEmailSubscription": {
      "Type": "AWS::SNS::Subscription",
      "Properties": {
        "TopicArn": {
          "Ref": "AlertsTopic"
        },
        "Protocol": "email",
        "Endpoint": "replace-with-your-email@example.com"
      }
    }
  },
  "Outputs": {
    "AlertsTopicArn": {
      "Value": {
        "Ref": "AlertsTopic"
      }
    }
  }
}
