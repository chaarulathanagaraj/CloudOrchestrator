{
  "name": "cloud-cost-guard-hourly",
  "groupName": "default",
  "scheduleExpression": "rate(3 hours)",
  "scheduleExpressionTimezone": "UTC",
  "state": "ENABLED",
  "flexibleTimeWindow": {
    "Mode": "OFF"
  },
  "target": {
    "arn": "arn:aws:lambda:us-east-1:123456789012:function:cloud-cost-guard-scanner",
    "roleArn": "arn:aws:iam::123456789012:role/EventBridgeInvokeLambdaRole",
    "input": "{\"trigger\":\"eventbridge-scheduler\"}"
  }
}
